# AI PROVIDER CONFIGURATION
# Set whichever provider's key you want to use — the server auto-detects which
# one is configured (priority order: OPENAI_API_KEY > GEMINI_API_KEY > ANTHROPIC_API_KEY).
# Set AI_PROVIDER to force a specific one if more than one key is set.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
AI_PROVIDER=""
# Optional model overrides (defaults: gpt-4o-mini / claude-haiku-4-5-20251001)
OPENAI_MODEL=""
ANTHROPIC_MODEL=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE CONFIGURATION: Required for multi-tenant and database logic
# These variables configure the connection to your Supabase project.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
SUPABASE_DB_PASSWORD=""
