# AI ROUTER CONFIGURATION
# Preferred setup: configure providers/keys/strategy from HQ Console -> Pusat
# Sistem -> AI Router. Those are stored in Supabase (ai_router_settings /
# ai_provider_configs) and read live by the server on every request — this is
# the source of truth for the whole app's AI behavior. Reading that DB config
# REQUIRES both VITE_SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY below to be set
# — if either is missing, the server silently skips the DB config entirely and
# falls through to the raw provider env vars below (and then, if none of
# those are set either, to the local fallback simulator).
# The env vars below are only a fallback used when no Supabase config exists.
# Set as many provider keys below as you like. The server tries them
# cheapest-first (default order: Gemini > OpenAI > Anthropic > DeepSeek >
# xAI > Mistral > Groq > Alibaba) and falls through to the next one
# automatically if a call fails (quota/billing/outage).
GEMINI_API_KEY="MY_GEMINI_API_KEY"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
DEEPSEEK_API_KEY=""
XAI_API_KEY=""
MISTRAL_API_KEY=""
GROQ_API_KEY=""
ALIBABA_API_KEY=""
# AI_PROVIDER_ORDER="openai,gemini,anthropic"   # optional: override cost order
# AI_PROVIDER="openai"                          # optional: pin to a single provider
# Optional model overrides (defaults: gpt-4o-mini / claude-haiku-4-5-20251001)
OPENAI_MODEL=""
ANTHROPIC_MODEL=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
PUBLIC_APP_URL=""

# SUPABASE CONFIGURATION: Required for multi-tenant and database logic
# These variables configure the connection to your Supabase project.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
SUPABASE_DB_PASSWORD=""
# SUPABASE_SERVICE_ROLE_KEY: REQUIRED in production. Used server-side for the
# AI Router DB config (ai_router_settings/ai_provider_configs), resource
# credit consumption (consume_resource_credit RPC), suspension checks, and
# session->tenant identity resolution. Without it, all of those silently
# fail-open/fail-closed to permissive defaults instead of erroring loudly —
# see server.ts fetchDbAiConfig()/consumeResourceCredit()/isUserSuspended()/
# resolveCallerIdentity().
SUPABASE_SERVICE_ROLE_KEY=""
NODE_ENV="production"
